generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ==========================================
// USER & AUTH MODELS (NextAuth v5)
// ==========================================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String?
  image         String?
  institution   String?
  location      String?
  bio           String?
  role          String    @default("researcher")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  analyses      Analysis[]
  batches       Batch[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ==========================================
// TREETRACE DOMAIN MODELS
// ==========================================

model Analysis {
  id                    String   @id @default(cuid())
  userId                String
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  imageName             String
  imageWidth            Int
  imageHeight           Int
  pithCx                Int
  pithCy                Int

  ringCount             Int
  estimatedAge          Int
  birthYear             Int
  samplingYear          Int

  statistics            Json
  trend                 Json
  health                Json
  anomalies             Json
  phases                Json
  carbon                Json
  biography             String
  rings                 Json

  precision             Float?
  recall                Float?
  f1Score               Float?
  rmse                  Float?

  overlayImagePath      String?
  csvExportPath         String?
  processingTimeSeconds Float
  status                String   @default("completed")
  errorMessage          String?

  batchId               String?
  batch                 Batch?   @relation(fields: [batchId], references: [id])

  alias                 String?
  notes                 String?
  tags                  String?

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([userId])
  @@index([batchId])
  @@index([createdAt])
  @@map("analyses")
}

model Batch {
  id          String     @id @default(cuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  name        String?
  status      String     @default("processing")

  totalImages    Int     @default(0)
  successCount   Int     @default(0)
  failedCount    Int     @default(0)

  analyses    Analysis[]

  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([userId])
  @@map("batches")
}
